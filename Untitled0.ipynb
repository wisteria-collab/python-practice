        "def judge(name, score):\n",
        "    if score >= 60:\n",
        "        print(name + \"さんは合格です\")\n",
        "    else:\n",
        "        print(name + \"さんは不合格です\")\n",
        "\n",
        "name = input(\"あなたの名前は？\")\n",
        "score = int(input(\"得点は？\"))\n",
        "judge(name, score)"
